meta {
  name: Upload Bank Statement
  type: http
  seq: 2
}

post {
  url: http://localhost:8000/api/upload
  body: multipartForm
  auth: none
}

body:multipart-form {
  file: @file(/path/to/your/bank_statement.csv)
}

vars:post-response {
  file_id: res.body.file_id
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Returns file_id", function() {
    var data = res.getBody();
    expect(data.file_id).to.be.a("string");
    expect(data.file_id.length).to.be.greaterThan(0);
  });

  test("Returns total_rows", function() {
    var data = res.getBody();
    expect(data.total_rows).to.be.a("number");
    expect(data.total_rows).to.be.greaterThan(0);
  });
}
