# MyMoney – Environment Variables
# Copy this file to .env and adjust as needed before running docker compose.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------

# URL of the Ollama API (used by the backend to request AI advice).
# In Docker Compose this points to the 'ollama' service automatically.
OLLAMA_URL=http://ollama:11434/api/generate

# Ollama model to use. Choices: llama3, llama3:8b, mistral, gemma, etc.
OLLAMA_MODEL=llama3

# Comma-separated list of allowed CORS origins.
# Use "*" to allow any origin (suitable for public deployments).
ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------

# Set to empty string in Docker so relative /api/* paths are used (proxied).
# In local dev without Docker, set to http://localhost:8000 to reach the API directly.
NEXT_PUBLIC_API_URL=

# Internal backend URL for Next.js server-side rewrites (Docker Compose only).
BACKEND_URL=http://backend:8000
